<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white">
    <View android:id="@+id/viewHeaderColor" android:layout_width="match_parent" android:layout_height="120dp" android:background="#9E9E9E" app:layout_constraintTop_toTopOf="parent" />
    <TextView android:id="@+id/tvDetalleMonto" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="$0.00" android:textSize="36sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/viewHeaderColor" app:layout_constraintBottom_toBottomOf="@id/viewHeaderColor" />
    <TextView android:id="@+id/tvDetalleDescripcion" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="24sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/viewHeaderColor" />
    <TextView android:id="@+id/tvDetalleCategoria" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textColor="@color/grey_text" app:layout_constraintTop_toBottomOf="@id/tvDetalleDescripcion" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp" app:layout_constraintTop_toBottomOf="@id/tvDetalleCategoria">
        <TextView android:text="Fecha:" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvDetalleFecha" android:textSize="18sp" android:layout_marginBottom="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:text="Notas:" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvDetalleNotas" android:textSize="16sp" android:fontFamily="monospace" android:background="@color/grey_light" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
