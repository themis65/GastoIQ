<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:title="Análisis"
            android:titleTextColor="@color/text_primary"
            app:navigationIcon="@android:drawable/ic_media_previous"
            app:navigationIconTint="@color/text_primary"/>

        <!-- Card: Últimos 6 meses -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÚLTIMOS 6 MESES"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.2"/>

            <!-- barras fake -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="16dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@color/accent"
                    android:alpha="0.5"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@color/accent"
                    android:alpha="0.5"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@color/accent"
                    android:alpha="0.5"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ene\n$966"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Feb\n$897"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mar\n$137"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Card: Gasto semanal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GASTO SEMANAL"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.2"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="16dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@color/accent"
                    android:alpha="0.5"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@color/accent"
                    android:alpha="0.25"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@color/accent"
                    android:alpha="0.25"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:background="@color/accent"
                    android:alpha="0.25"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S1\n$137"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S2\n$0"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S3\n$0"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S4\n$0"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Patrones detectados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PATRONES DETECTADOS"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="🍔  Mayor gasto: Comida ($49)"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_card"
                android:padding="14dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="📊  Promedio diario: $34.29"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_card"
                android:padding="14dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="💡  Quedan $163 para 26 días ($6.26/día)"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_card"
                android:padding="14dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Reiniciar datos"
            app:strokeColor="@color/danger"
            app:strokeWidth="1dp"
            android:textColor="@color/danger"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="30dp"/>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>